{
  "name": "pokedex",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "description": "A fully static, accessible, locale-aware Pokédex built on TanStack Start. Powered by a local PokéAPI mirror.",
  "homepage": "https://projects.sujeet.pro/pokedex",
  "scripts": {
    "dev": "vite dev",
    "build": "npm run bundles:build && vite build",
    "preview": "vite preview",
    "check": "npm run lint && npm run format:check && npm run typecheck",
    "lint": "oxlint src scripts",
    "lint:fix": "oxlint --fix src scripts",
    "format": "oxfmt src scripts",
    "format:check": "oxfmt --check src scripts",
    "typecheck": "tsgo --noEmit -p tsconfig.app.json && tsgo --noEmit -p tsconfig.node.json",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "data:sync": "tsx scripts/sync-data.ts",
    "bundles:build": "tsx scripts/build-bundles.ts",
    "summaries:build": "tsx scripts/summarize.ts --concurrency 2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@tanstack/react-hotkeys": "^0.9.1",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260420.1",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^26.0.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
