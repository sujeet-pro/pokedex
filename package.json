{
  "name": "pokedex",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "A modern, accessible Pokédex built with Vite+ (vite, vitest, oxc) and React 19. Powered by the PokéAPI.",
  "homepage": "https://projects.sujeet.pro/pokedex",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && npm run bundles:build && vite build",
    "preview": "vite preview",
    "check": "npm run lint && npm run format:check && npm run typecheck",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "typecheck": "tsgo --noEmit -p tsconfig.app.json && tsgo --noEmit -p tsconfig.node.json",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "data:sync": "tsx scripts/sync-data.ts",
    "bundles:build": "tsx scripts/build-bundles.ts",
    "summaries:build": "tsx scripts/summarize.ts --concurrency 2"
  },
  "dependencies": {
    "@tanstack/react-hotkeys": "^0.9.1",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260419.1",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "^19.0.0-beta-37ed2a7-20241206",
    "jsdom": "^26.0.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^0.15.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
